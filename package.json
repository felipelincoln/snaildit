{
  "name": "snaildit",
  "version": "0.1.0",
  "description": "A self-hosted GitHub AI bot running on your Codex subscription.",
  "type": "module",
  "license": "MIT",
  "author": "Felipe Lincoln <felipe8d63@gmail.com>",
  "homepage": "https://github.com/felipelincoln/snaildit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipelincoln/snaildit.git"
  },
  "bugs": {
    "url": "https://github.com/felipelincoln/snaildit/issues"
  },
  "keywords": [
    "github",
    "bot",
    "codex",
    "ai",
    "webhook",
    "automation",
    "self-hosted"
  ],
  "engines": {
    "node": ">=24.15"
  },
  "bin": {
    "snaildit": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && vite build && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "start": "node dist/cli.js start",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@phosphor-icons/react": "2.1.10",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "24.13.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "radix-ui": "1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "dependencies": {
    "@octokit/auth-app": "8.2.0",
    "@octokit/core": "7.0.6",
    "@octokit/plugin-paginate-rest": "14.0.0",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3"
  }
}
